{
  "name": "pulsegrid",
  "version": "1.0.0",
  "description": "PulseGrid — Predictive digital twin for FIFA World Cup 2026 stadium operations",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server/index.js\"",
    "dev:client": "vite",
    "server": "node server/index.js",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.1.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
